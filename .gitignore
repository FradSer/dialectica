# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
wheels/
*.egg
*.egg-info/
.eggs/

# --- Virtual environments ---
.venv/
venv/

# --- Tool caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
coverage.xml

# --- Secrets (keep .env.example tracked) ---
.env
.env.*
!.env.example

# --- Dialectica runtime (workflow resume/journal; override with DIALECTICA_WORKFLOW_JOURNAL_DIR) ---
.dialectica/

# --- Eval harness outputs (tool is tracked; results are not) ---
evals/results/

# --- git-agent local state (config.yml may be tracked) ---
.git-agent/graph.db
.git-agent/*.db

# --- IDE / editor ---
.cursor/
.idea/
.vscode/
*.swp
*~

# --- OS ---
.DS_Store
Thumbs.db
